# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL via Prisma) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cred2tech?schema=public

# ─── Auth / integrations (fill with real values in prod) ───────────────────────
JWT_SECRET=change-me
# User-facing frontend URL, used to build links sent in emails (password reset).
FRONTEND_URL=http://localhost:3000
# SMTP for transactional emails (password reset, proposal dispatch). Unset = no-op.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Gates /api-docs (Swagger UI) with HTTP Basic Auth. Leave unset to block
# API docs entirely (fails closed) — only set in environments where the
# docs should be reachable.
SWAGGER_DOCS_USER=
SWAGGER_DOCS_PASSWORD=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── PII field encryption (src/utils/fieldEncryption.js) ────────────────────────
# 32 random bytes, base64-encoded (e.g. `openssl rand -base64 32`). Required —
# the app fails fast at startup if unset. Do not reuse BACKUP_ENCRYPTION_KEY.
FIELD_ENCRYPTION_KEY=change-me-base64-32-bytes

# ─── Database backup (scripts/db-backup.sh → local + S3) ───────────────────────
# Client-side AES-256 encryption key for backups (32+ random chars).
BACKUP_ENCRYPTION_KEY=change-me-32-char-random-string
# Offsite backup bucket.
S3_BACKUP_BUCKET=cred2tech-db-backups

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
