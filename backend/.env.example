# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL via Prisma) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cred2tech?schema=public

# ─── Auth / integrations (fill with real values in prod) ───────────────────────
JWT_SECRET=change-me
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Database backup (scripts/db-backup.sh → local + S3) ───────────────────────
# Client-side AES-256 encryption key for backups (32+ random chars).
BACKUP_ENCRYPTION_KEY=change-me-32-char-random-string
# Offsite backup bucket.
S3_BACKUP_BUCKET=cred2tech-db-backups

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
