generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  CRED2TECH
  DSA
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
  permissions String[] @default([])

  @@map("roles")
}

model Tenant {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  mobile     String?
  type       TenantType
  status     TenantStatus @default(ACTIVE)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  // Audit tracking fields
  created_by Int?
  updated_by Int?

  // Compliance metadata fields
  pan_number   String?
  gst_number   String?
  company_type String?
  state        String?
  city         String?
  pincode      String?

  users                     User[]
  customers                 Customer[]
  cases                     Case[]
  otps                      OtpVerification[]
  wallet                    TenantWallet?
  transactions              WalletTransaction[]
  api_logs                  ApiUsageLog[]
  api_pricing_overrides     TenantApiPricingOverride[]
  gst_requests              GstrAnalyticsRequest[]
  bank_statements           BankStatementAnalysisRequest[]
  itr_analytics             ItrAnalyticsRequest[]
  documents                 Document[]
  tenant_lenders            TenantLender[]
  commission_rules          LenderCommissionRule[]
  audit_logs                AuditLog[]
  eligibility_reports       EligibilityReport[]
  proposals                 Proposal[]
  sanctions                 CaseSanction[]
  disbursements             Disbursement[]
  pdd_tasks                 PDDTask[]
  salary_ocr_results        SalarySlipOcrResult[]
  commission_ledgers        CommissionLedger[]
  SubDsaPayoutRule          SubDsaPayoutRule[]
  SubDsaPayoutLedger        SubDsaPayoutLedger[]
  SubDsaInvoice             SubDsaInvoice[]
  WalletTopupRequest        WalletTopupRequest[]
  EmployeeWallet            EmployeeWallet[]
  EmployeeWalletTransaction EmployeeWalletTransaction[]
  SalesIncentiveRule        SalesIncentiveRule[]
  SalesIncentiveLedger      SalesIncentiveLedger[]

  data_pull_background_jobs DataPullBackgroundJob[]
  system_notifications      SystemNotification[]

  @@map("tenants")
}

model User {
  id              Int        @id @default(autoincrement())
  name            String
  email           String     @unique
  mobile          String?
  password_hash   String
  role_id         Int
  tenant_id       Int
  hierarchy_level String?
  manager_id      Int?
  hierarchy_path  String?
  status          UserStatus @default(ACTIVE)
  designation     String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  created_by    Int?
  updated_by    Int?
  last_login_at DateTime?
  failed_login_attempts Int @default(0)
  locked_until  DateTime?

  role         Role   @relation(fields: [role_id], references: [id])
  tenant       Tenant @relation(fields: [tenant_id], references: [id])
  manager      User?  @relation("UserToManager", fields: [manager_id], references: [id])
  subordinates User[] @relation("UserToManager")

  created_customers         Customer[]                  @relation("CustomerCreator")
  created_cases             Case[]                      @relation("CaseCreator")
  created_otps              OtpVerification[]           @relation("OtpCreator")
  msme_customer_cases       Case[]                      @relation("MsmeCustomerUser")
  assigned_dsa_cases        Case[]                      @relation("AssignedDsaUser")
  allocated_msme_cases      Case[]                      @relation("AllocatingAdmin")
  case_payments             CasePayment[]
  api_logs                  ApiUsageLog[]
  activity_logs             ActivityLog[]
  audit_logs                AuditLog[]
  stage_history             CaseStageHistory[]
  SubDsaPayoutRule          SubDsaPayoutRule?
  SubDsaPayoutLedger        SubDsaPayoutLedger[]
  SubDsaInvoice             SubDsaInvoice[]
  SubDsaPayoutHistory       SubDsaPayoutHistory[]
  WalletTopupRequest        WalletTopupRequest[]
  EmployeeWallet            EmployeeWallet[]
  EmployeeWalletTransaction EmployeeWalletTransaction[]
  SalesIncentiveLedger      SalesIncentiveLedger[]

  password_reset_tokens     PasswordResetToken[]
  user_sessions             UserSession[]

  @@index([tenant_id])
  system_notifications      SystemNotification[]

  @@index([manager_id])
  @@map("users")
}

// --- Onboarding Flow Models ---

enum CustomerCategory {
  MSME
  SALARIED
}

model Customer {
  id               Int              @id @default(autoincrement())
  tenant_id        Int
  category         CustomerCategory @default(MSME)
  business_pan     String
  business_name    String?
  business_mobile  String?
  business_email   String?
  entity_type      String?
  dob              String?
  industry         String?
  business_vintage String?
  is_professional  Boolean          @default(false)
  profession_type  String?
  mobile_verified  Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  legal_business_name  String?
  trade_name           String?
  proprietor_name      String?
  pan_holder_name      String?
  business_name_source String?

  created_by_user_id Int

  tenant             Tenant                         @relation(fields: [tenant_id], references: [id])
  created_by         User                           @relation("CustomerCreator", fields: [created_by_user_id], references: [id])
  cases              Case[]
  api_logs           ApiUsageLog[]
  activity_logs      ActivityLog[]
  consents           CustomerConsent[]
  gst_profiles       CustomerGSTProfile[]
  pan_profiles       CustomerPanProfile[]
  gst_requests       GstrAnalyticsRequest[]
  bank_statements    BankStatementAnalysisRequest[]
  itr_analytics      ItrAnalyticsRequest[]
  documents          Document[]
  salary_ocr_results SalarySlipOcrResult[]

  @@unique([tenant_id, business_pan])
  @@map("customers")
}

model CustomerPanProfile {
  id                       Int      @id @default(autoincrement())
  customer_id              Int
  pan                      String   @unique
  gstin                    String?
  constitution_of_business String?
  legal_name               String?
  trade_name               String?
  principal_state          String?
  principal_city           String?
  principal_pincode        String?
  principal_address        String?
  director_names           Json?
  annual_turnover_range    String?
  turnover_min             Float?
  turnover_max             Float?
  gross_total_income       String?
  income_financial_year    String?
  raw_response             Json
  created_at               DateTime @default(now())

  customer      Customer                 @relation(fields: [customer_id], references: [id])
  gstin_records CustomerPanGstinRecord[]

  @@map("customer_pan_profiles")
}

model CustomerPanGstinRecord {
  id                Int      @id @default(autoincrement())
  pan_profile_id    Int
  gstin             String
  registration_name String?
  status            String?
  created_at        DateTime @default(now())

  pan_profile CustomerPanProfile @relation(fields: [pan_profile_id], references: [id])

  @@map("customer_pan_gstin_records")
}

enum CaseStage {
  DRAFT
  LEAD_CREATED
  DATA_COLLECTION
  INCOME_REVIEWED
  ESR_GENERATED
  LEAD_SENT_TO_LENDER
  IN_REVIEW
  APPROVED
  REJECTED
  DISBURSED
  PARTLY_DISBURSED
  CLOSED
}

model Case {
  id             Int       @id @default(autoincrement())
  tenant_id      Int
  customer_id    Int
  product_type   String? // LAP, HL, WC, TL, ML, BL, Other
  loan_amount    Float?
  lender_name    String? // DEPRECATED: use case_lender_selections (Phase 2)
  property_type  String? // DEPRECATED: use case_property_details
  occupancy      String? // DEPRECATED: use case_property_details
  property_value Float? // DEPRECATED: use case_property_details
  location       String? // DEPRECATED: use case_property_details
  ltv_ratio      Float? // DEPRECATED: computed during ESR
  dsa_notes      String?
  esr_generated  Boolean   @default(false) // NEW Phase 1
  stage          CaseStage @default(DRAFT)

  // Direct MSME Flow Fields
  lead_source                 String?   @default("DSA") // "DSA" | "DIRECT_MSME"
  msme_customer_user_id       Int?      // The MSME User who owns this case
  assigned_dsa_tenant_id      Int?      // Set when admin allocates to DSA
  assigned_dsa_user_id        Int?      // Set when admin allocates to DSA user
  allocated_by_admin_id       Int?      // Cred2Tech admin who did allocation
  allocated_at                DateTime?
  msme_submitted_at           DateTime? // When MSME clicked "Submit"
  msme_selected_lender_esr_id Int?      // EligibilityReportLender.id chosen

  // Pipeline Snapshot Fields (Performance Design)
  customer_name String?
  entity_type   String?
  cibil_score   Int?
  alert_flag    String?
  lead_date     DateTime @default(now())
  is_locked     Boolean  @default(false)

  // Financial Summary Snapshot (Source of Truth is Disbursement table)
  sanctioned_amount             Decimal?  @db.Decimal(18, 2)
  total_disbursed_amount        Decimal?  @default(0) @db.Decimal(18, 2)
  remaining_disbursement_amount Decimal?  @default(0) @db.Decimal(18, 2)
  first_disbursement_date       DateTime?
  last_disbursement_date        DateTime?

  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  proposal_sent_at         DateTime?
  proposal_sent_by_user_id Int?

  created_by_user_id Int

  // Lender-Specific Child Case Fields
  parent_case_id     Int?
  platform_lender_id Int?
  tenant_lender_id   Int?
  contact_id         Int?
  dsa_code           String?
  contact_name       String?
  contact_email      String?
  contact_mobile     String?
  is_cloned_snapshot Boolean @default(false)

  tenant           Tenant                         @relation(fields: [tenant_id], references: [id])
  customer         Customer                       @relation(fields: [customer_id], references: [id])
  created_by       User                           @relation("CaseCreator", fields: [created_by_user_id], references: [id])
  msme_customer_user User?                        @relation("MsmeCustomerUser", fields: [msme_customer_user_id], references: [id])
  assigned_dsa_user  User?                        @relation("AssignedDsaUser", fields: [assigned_dsa_user_id], references: [id])
  allocated_by_admin User?                        @relation("AllocatingAdmin", fields: [allocated_by_admin_id], references: [id])
  case_payment       CasePayment?
  parent_case      Case?                          @relation("ParentChildCase", fields: [parent_case_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  child_cases      Case[]                         @relation("ParentChildCase")
  applicants       Applicant[]
  api_logs         ApiUsageLog[]
  activity_logs    ActivityLog[]
  data_pull_status CaseDataPullStatus?
  consents         CustomerConsent[]
  gst_requests     GstrAnalyticsRequest[]
  bank_statements  BankStatementAnalysisRequest[]
  itr_analytics    ItrAnalyticsRequest[]
  bureau_checks    BureauVerification[]
  documents        Document[]
  // Phase 1 relations
  property         CasePropertyDetails?
  income_entries   CaseIncomeEntry[]
  obligations      CaseCreditObligation[]
  esrs             EligibilityReport[]
  esr_financials   CaseEsrFinancials?
  stage_history    CaseStageHistory[]
  proposals        Proposal[]

  // Sanction & Disbursement
  sanction             CaseSanction?
  disbursements        Disbursement[]
  pdd_tasks            PDDTask[]
  salary_ocr_results   SalarySlipOcrResult[]
  commission_ledgers   CommissionLedger[]
  SubDsaPayoutLedger   SubDsaPayoutLedger[]
  SalesIncentiveLedger SalesIncentiveLedger[]

  @@index([tenant_id, stage])
  @@index([tenant_id, lender_name])
  data_pull_background_jobs DataPullBackgroundJob[]
  system_notifications      SystemNotification[]

  @@index([tenant_id, lead_date])
  @@map("cases")
}

enum ApplicantType {
  PRIMARY
  CO_APPLICANT
}

enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  NA
}

model Applicant {
  id                  Int            @id @default(autoincrement())
  case_id             Int
  type                ApplicantType
  employment_type     EmploymentType @default(NA)
  name                String? // Phase 1: display name for bureau/income pages
  pan_number          String?
  dob                 String?
  mobile              String?
  email               String?
  cibil_score         Int?
  emi                 Float? // DEPRECATED: use sum of CaseCreditObligation.emi_per_month
  is_primary          Boolean        @default(false)
  otp_verified        Boolean        @default(false)
  bureau_fetched      Boolean        @default(false)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  source_applicant_id Int? // To map parent applicant to child applicant

  pan_verified                 Boolean   @default(false)
  pan_verified_at              DateTime?
  pan_verification_status      String?
  pan_verification_reference   String?
  pan_verified_name            String?
  pan_verified_dob             String?
  pan_verification_response    Json?
  pan_verified_by_user_id      Int?

  case               Case                           @relation(fields: [case_id], references: [id], onDelete: Cascade)
  bank_statements    BankStatementAnalysisRequest[]
  itr_analytics      ItrAnalyticsRequest[]
  gstr_analytics     GstrAnalyticsRequest[]
  bureau_checks      BureauVerification[]
  documents          Document[]
  salary_ocr_results SalarySlipOcrResult[]
  // Phase 1 relations
  income_entries     CaseIncomeEntry[]
  obligations        CaseCreditObligation[]

  data_pull_background_jobs DataPullBackgroundJob[]

  @@map("applicants")
}

model ActivityLog {
  id                   Int      @id @default(autoincrement())
  case_id              Int?
  customer_id          Int?
  activity_type        String
  description          String?
  performed_by_user_id Int?
  created_at           DateTime @default(now())

  case_entity Case?     @relation(fields: [case_id], references: [id])
  customer    Customer? @relation(fields: [customer_id], references: [id])
  user        User?     @relation(fields: [performed_by_user_id], references: [id])

  @@index([case_id])
  @@index([customer_id])
  @@map("activity_logs")
}

model CaseStageHistory {
  id         Int       @id @default(autoincrement())
  case_id    Int
  tenant_id  Int
  old_stage  CaseStage
  new_stage  CaseStage
  changed_by Int?
  changed_at DateTime  @default(now())

  case Case  @relation(fields: [case_id], references: [id])
  user User? @relation(fields: [changed_by], references: [id])

  @@index([case_id])
  @@index([tenant_id])
  @@map("case_stage_history")
}

enum OtpPurpose {
  PRIMARY_APPLICANT
  CO_APPLICANT
}

enum OtpTargetType {
  CUSTOMER
  APPLICANT
}

model OtpVerification {
  id                 Int           @id @default(autoincrement())
  tenant_id          Int
  created_by_user_id Int
  mobile             String
  otp_hash           String
  purpose            OtpPurpose
  target_type        OtpTargetType
  target_id          Int
  is_verified        Boolean       @default(false)
  expires_at         DateTime
  attempt_count      Int           @default(0)
  created_at         DateTime      @default(now())
  verified_at        DateTime?

  tenant     Tenant @relation(fields: [tenant_id], references: [id])
  created_by User   @relation("OtpCreator", fields: [created_by_user_id], references: [id])

  @@index([tenant_id, target_type, target_id])
  @@index([mobile])
  @@map("otp_verifications")
}

model LoginOtp {
  id            Int       @id @default(autoincrement())
  mobile        String
  otp_hash      String
  purpose       String    @default("MSME_CUSTOMER_LOGIN")
  is_verified   Boolean   @default(false)
  attempt_count Int       @default(0)
  expires_at    DateTime
  verified_at   DateTime?
  created_at    DateTime  @default(now())

  @@index([mobile])
  @@map("login_otps")
}

model CasePayment {
  id                   Int       @id @default(autoincrement())
  user_id              Int
  case_id              Int?      @unique
  purpose              String
  amount_inr           Decimal   @db.Decimal(12, 2)
  amount_paise         Int
  currency             String    @default("INR")
  razorpay_order_id    String?   @unique
  razorpay_payment_id  String?
  razorpay_signature   String?
  status               String    @default("INITIATED")
  failure_reason       String?
  gst_amount           Decimal?  @db.Decimal(12, 2)
  idempotency_key      String?   @unique
  verified_at          DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  user        User  @relation(fields: [user_id], references: [id])
  case_entity Case? @relation(fields: [case_id], references: [id])

  @@index([user_id])
  @@index([case_id])
  @@index([razorpay_order_id])
  @@map("case_payments")
}

// --- Wallet & Credit Billing Models ---

model ApiPricing {
  id                  Int      @id @default(autoincrement())
  api_code            String   @unique
  api_name            String?
  description         String?
  vendor_cost         Float    @default(0)
  default_credit_cost Int      @default(0)
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  updated_by          Int?

  @@map("api_pricing")
}

model VolumeDiscount {
  id               Int      @id @default(autoincrement())
  min_topup_amount Float
  bonus_percentage Float
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("volume_discounts")
}

model TenantApiPricingOverride {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  api_code           String
  custom_credit_cost Int
  created_at         DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, api_code])
  @@map("tenant_api_pricing_overrides")
}

enum WalletStatus {
  ACTIVE
  BLOCKED
}

model TenantWallet {
  id         Int          @id @default(autoincrement())
  tenant_id  Int          @unique
  balance    Int          @default(0)
  status     WalletStatus @default(ACTIVE)
  updated_at DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("tenant_wallets")
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionReferenceType {
  API_CALL
  ADMIN_TOPUP
  REFUND
  MANUAL_ADJUSTMENT
  RAZORPAY_TOPUP
  EMPLOYEE_ALLOCATION
  EMPLOYEE_REVOCATION
}

model WalletTransaction {
  id               Int                      @id @default(autoincrement())
  tenant_id        Int
  amount           Int
  transaction_type TransactionType
  reference_type   TransactionReferenceType
  reference_id     Int?
  idempotency_key  String?                  @unique
  api_code         String?
  remarks          String?
  balance_after    Int
  created_by       Int?
  created_at       DateTime                 @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("wallet_transactions")
}

model WalletTopupRequest {
  id                   Int       @id @default(autoincrement())
  tenant_id            Int
  requested_by_user_id Int
  amount_inr           Decimal   @db.Decimal(12, 2)
  amount_paise         Int
  credits_to_add       Int
  currency             String    @default("INR")
  razorpay_order_id    String?   @unique
  razorpay_payment_id  String?
  razorpay_event_id    String?
  status               String    @default("INITIATED")
  failure_code         String?
  failure_reason       String?
  verified_at          DateTime?
  credited_at          DateTime?
  failed_at            DateTime?
  metadata             Json?
  raw_checkout_payload Json?
  raw_webhook_payload  Json?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [requested_by_user_id], references: [id])

  @@map("wallet_topup_requests")
}

model RazorpayWebhookEvent {
  id                  Int       @id @default(autoincrement())
  razorpay_event_id   String    @unique
  event_type          String
  razorpay_order_id   String?
  razorpay_payment_id String?
  processed           Boolean   @default(false)
  raw_payload         Json
  received_at         DateTime  @default(now())
  processed_at        DateTime?

  @@map("razorpay_webhook_events")
}

enum ApiUsageStatus {
  SUCCESS
  FAILED
  REFUNDED
  BLOCKED_INSUFFICIENT_CREDITS
  BLOCKED_INACTIVE_API
}

model ApiUsageLog {
  id                   Int            @id @default(autoincrement())
  tenant_id            Int
  triggered_by_user_id Int
  customer_id          Int
  case_id              Int?
  api_code             String
  credits_used         Int            @default(0)
  status               ApiUsageStatus
  request_payload      Json?
  response_payload     Json?
  response_status      String?
  error_message        String?
  reference_id         Int?
  idempotency_key      String?
  created_at           DateTime       @default(now())

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  user        User     @relation(fields: [triggered_by_user_id], references: [id])
  customer    Customer @relation(fields: [customer_id], references: [id])
  case_entity Case?    @relation(fields: [case_id], references: [id])

  @@unique([tenant_id, api_code, idempotency_key])
  @@index([tenant_id, api_code])
  @@index([customer_id])
  @@map("api_usage_logs")
}

// --- API Integrations & Financial Pulls ---

enum ConsentType {
  GST
  ITR
  PAN
}

enum ConsentSource {
  DIRECT_LOGIN
  LINK_SENT
}

enum ConsentStatus {
  GRANTED
  PENDING
  REVOKED
}

model CustomerConsent {
  id             Int           @id @default(autoincrement())
  customer_id    Int
  case_id        Int?
  consent_type   ConsentType
  consent_source ConsentSource
  status         ConsentStatus
  granted_at     DateTime?
  created_at     DateTime      @default(now())

  customer    Customer @relation(fields: [customer_id], references: [id])
  case_entity Case?    @relation(fields: [case_id], references: [id])

  @@map("customer_consents")
}

model CustomerGSTProfile {
  id                Int      @id @default(autoincrement())
  customer_id       Int
  gstin             String
  filing_status     String
  last_filed_period String
  annual_turnover   Float
  raw_response      Json
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])

  @@map("customer_gst_profiles")
}

enum GstrRequestMode {
  AUTH_LINK
  IN_SYSTEM
}

enum GstrAuthType {
  OTP
  PASSWORD
}

enum GstrAnalyticsStatus {
  INITIATED
  AUTH_LINK_CREATED
  OTP_PENDING
  OTP_VERIFIED
  PROCESSING
  DATA_READY
  REPORT_READY
  CALLBACK_RECEIVED
  COMPLETED
  FAILED
  EXPIRED
}

model GstrAnalyticsRequest {
  id                    Int                 @id @default(autoincrement())
  tenant_id             Int
  customer_id           Int
  case_id               Int?
  applicant_id          Int? // NEW: Allow applicant-scoped GST
  mode                  GstrRequestMode
  auth_type             GstrAuthType?
  gstin                 String
  username              String?
  from_date             String
  to_date               String
  entity_details        Boolean             @default(false)
  pdf_url_requested     Boolean             @default(false)
  emails                Json?
  mobile_numbers        Json?
  callback_url          String?
  provider_request_id   String?             @unique
  auth_link             String?
  status                GstrAnalyticsStatus @default(INITIATED)
  provider_message      String?
  provider_callback_payload Json?
  raw_fetch_data        Json?
  raw_report_data       Json?
  raw_gst_data          Json? // Temporarily kept for backward compatibility

  provider_name         String?
  provider_api_version  String?
  payload_version       String?
  processing_version    Int                 @default(1)

  report_status         String              @default("PENDING")
  metrics_status        String              @default("PENDING")
  metrics_extracted_at  DateTime?
  metrics_error         String?

  report_json_url       String? // Source audit URL — NOT used for serving
  report_excel_url      String? // Source audit URL — NOT used for serving
  report_pdf_url        String? // Source audit URL — NOT used for serving
  callback_payload      Json?
  wallet_transaction_id Int?
  otp_attempts          Int                 @default(0)
  // Document storage references (populated after vendor URL ingestion)
  gst_pdf_document_id   Int?
  gst_excel_document_id Int?
  gst_json_document_id  Int?

