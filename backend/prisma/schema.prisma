// ─── Document Storage System ──────────────────────────────────────────────────

enum DocumentType {
  GST_REPORT_PDF
  GST_REPORT_EXCEL
  GST_REPORT_JSON
  ITR_EXCEL
  BANK_EXCEL
  BANK_JSON
  PAN_CARD
  AADHAAR
  GST_PDF
  ITR
  BANK_STATEMENT
  PROPERTY_DOCUMENT
  SALE_DEED
  SALARY_SLIP
  OTHER
}

enum DocumentSource {
  VENDOR_DOWNLOAD // Downloaded from a vendor-provided URL (Signzy etc.)
  DIRECT_UPLOAD // Uploaded directly by user
  SYSTEM_GENERATED // Created internally
}

enum DocumentStatus {
  ACTIVE
  FAILED
  DELETED
}

enum StorageProvider {
  LOCAL
  CLOUDFLARE_R2
  S3
}

model Document {
  id           Int  @id @default(autoincrement())
  tenant_id    Int
  customer_id  Int?
  case_id      Int?
  applicant_id Int?

  document_type DocumentType
  source_type   DocumentSource
  /// Original vendor URL kept for audit/debug — app NEVER uses this to serve
  source_url    String?

  storage_provider StorageProvider @default(LOCAL)
  /// Relative path/key within the storage root — never exposed to frontend
  storage_path     String

  file_name          String // System-generated safe filename
  original_file_name String? // Filename as received (for display only)
  mime_type          String
  extension          String
  file_size_bytes    Int?
  checksum_md5       String?

  status              DocumentStatus @default(ACTIVE)
  uploaded_by_user_id Int?
  metadata            Json? // Extensible — store any extra provider data
  deleted_at          DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant                 Tenant               @relation(fields: [tenant_id], references: [id])
  customer               Customer?            @relation(fields: [customer_id], references: [id])
  case_entity            Case?                @relation(fields: [case_id], references: [id])
  applicant              Applicant?           @relation(fields: [applicant_id], references: [id])
  proposal_docs          ProposalDocument[]
  salary_slip_ocr_result SalarySlipOcrResult?

  @@index([tenant_id])
  @@index([customer_id])
  @@index([case_id])
  @@index([tenant_id, document_type])
  @@map("documents")
}

// ─── Phase 1: Onboarding Extension Models ────────────────────────────────────

model CasePropertyDetails {
  id               Int      @id @default(autoincrement())
  case_id          Int      @unique
  property_type    String? // Commercial / Residential / Industrial / Plot
  occupancy_status String? // Self Occupied / Rented Out / Vacant
  ownership_type   String? // Sole Owner / Joint Owner / Company Owned
  market_value     Float? // DSA estimate in INR
  remarks          String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  case_entity Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@map("case_property_details")
}

model CaseIncomeEntry {
  id                  Int      @id @default(autoincrement())
  case_id             Int
  applicant_id        Int?
  income_type         String // Director Salary / Rental Income / Agriculture Income / Other...
  applicant_label     String? // Human-readable label (e.g. "Rajesh Kumar")
  annual_amount       Float
  supporting_doc_type String? // CA Certificate / Salary Slip / Form 16 / Bank Credit / None
  remarks             String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  case_entity Case       @relation(fields: [case_id], references: [id], onDelete: Cascade)
  applicant   Applicant? @relation(fields: [applicant_id], references: [id], onDelete: SetNull)

  @@index([case_id])
  @@index([applicant_id])
  @@map("case_income_entries")
}

model CaseCreditObligation {
  id                 Int       @id @default(autoincrement())
  case_id            Int
  applicant_id       Int
  lender_name        String?
  loan_type          String? // Home Loan / Car Loan / Business Loan / Personal Loan / etc.
  loan_amount        Float?
  outstanding_amount Float?
  loan_start_date    DateTime?
  emi_per_month      Float     @default(0)
  status             String    @default("ACTIVE") // ACTIVE | CLOSED | NPA | VERIFY
  source             String    @default("BUREAU") // BUREAU | MANUAL
  needs_verification Boolean   @default(false) // true when bureau EMI = 0
  include_in_foir    Boolean   @default(true) // NEW: For ESR FOIR calculation
  remarks            String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  case_entity Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  applicant   Applicant @relation(fields: [applicant_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@index([applicant_id])
  @@index([case_id, applicant_id])
  @@map("case_credit_obligations")
}

model CaseEsrFinancials {
  id                      Int     @id @default(autoincrement())
  case_id                 Int     @unique
  requested_loan_amount   Float?
  requested_tenure_months Int?
  product_type            String?

  property_value Float?
  property_type  String?
  occupancy_type String?

  bureau_score         Int?
  applicant_age        Int?
  existing_obligations Float?
  icici_exposure       Float?

  itr_pat            Float?
  itr_depreciation   Float?
  itr_finance_cost   Float?
  itr_gross_receipts Float?

  gst_avg_monthly_sales Float?
  gst_industry_type     String?
  gst_industry_margin   Float?

  bank_avg_balance        Float?
  bank_total_credits      Float?
  bank_avg_monthly_credit Float?
  bank_monthly_income     Float?

  net_profit_income Float?
  gst_income        Float?
  banking_income    Float?

  // --- Salaried Income Fields (Phase 2) ---
  salaried_income        Float? // avg net monthly salary derived from OCR + manual income entries
  salaried_income_source String? // "OCR" | "MANUAL" | "MIXED"
  salaried_slip_count    Int? // number of OCR-completed salary slips used in derivation

  selected_income_method  String?
  selected_monthly_income Float?

  constitution_type       String?
  employment_type         String?
  business_vintage_months Int?

  // --- Extraction Lifecycle (Phase 2) ---
  // Tracks whether the snapshot is fresh and safe to use for ESR generation
  extraction_status String    @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED"
  extracted_at      DateTime? // timestamp of last successful extraction

  // ── NPM (Net Profit Method) Addbacks ──────────────────────────────────────
  itr_remuneration Float?

  // ── Double Whammy Flag ────────────────────────────────────────────────────
  double_whammy_flag Boolean @default(false)

  // ── Net Worth Method (NWM) Inputs ─────────────────────────────────────────
  net_worth Float?

  // ── Salaried Income Components ────────────────────────────────────────────
  salaried_incentive_income Float?
  salaried_other_income     Float?

  // ── Manual Eligibility Overrides (LIP / Low LTV / Manual) ────────────────
  manual_eligible_loan_amount Float?
  manual_proposed_emi         Float?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  case_entity Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@map("case_esr_financials")
}

model EligibilityReport {
  id        Int @id @default(autoincrement())
  case_id   Int
  tenant_id Int

  version_number Int
  is_latest      Boolean @default(true)

  generated_at         DateTime @default(now())
  generated_by_user_id Int?

  combined_income     Float?
  property_value      Float?
  primary_cibil_score Int?
  lowest_cibil_score  Int?
  total_emi_per_month Float?

  input_snapshot Json
  raw_payload    Json? // Debugging only

  status String @default("GENERATED")

  lenders EligibilityReportLender[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  case_entity Case   @relation(fields: [case_id], references: [id], onDelete: Cascade)
  tenant      Tenant @relation(fields: [tenant_id], references: [id])

  // UNIQUE constraint: guarantees one version_number per case+tenant combination.
  // This is the database-level safety net for concurrent ESR generation.
  // Even if the advisory lock is bypassed, the DB will reject the duplicate insert.
  @@unique([case_id, tenant_id, version_number])
  @@index([case_id, tenant_id, is_latest])
  @@map("eligibility_reports")
}

model EligibilityReportLender {
  id               Int     @id @default(autoincrement())
  esr_id           Int
  tenant_lender_id Int?
  lender_id        String?

  lender_name          String
  product_type         String
  product_display_name String?
  best_scheme_name     String?
  is_eligible          Boolean

  eligible_amount Float?
  roi             Float?
  tenure_months   Int?
  emi             Float?
  ltv             Float?
  foir            Float?

  remarks            String?
  rejection_reasons  Json?
  scheme_evaluations Json?

  created_at DateTime @default(now())

  esr EligibilityReport @relation(fields: [esr_id], references: [id], onDelete: Cascade)

  @@map("eligibility_report_lenders")
}

