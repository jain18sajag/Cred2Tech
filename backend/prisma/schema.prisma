enum DataPullType {
  GST
  ITR
  BANK
  BUREAU
}

enum DataPullFlowType {
  GST_AUTH_LINK
  GST_OTP
  GST_PASSWORD
  ITR_FORM
  ITR_ANALYTICS
  BANK_STATEMENT
  BUREAU
}

enum DataPullJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
  AWAITING_CUSTOMER_ACTION
}

enum PullNotificationStatus {
  COMPLETED
  FAILED
  EXPIRED
  ACTION_REQUIRED
}

enum NotificationAudienceType {
  USER
  CASE_OWNER
  CASE_ASSIGNEE
  TENANT_PERMISSION
  TENANT_ROLE
}

model DataPullBackgroundJob {
  id                     Int                @id @default(autoincrement())
  tenant_id              Int
  case_id                Int
  applicant_id           Int?
  pull_type              DataPullType
  module_request_id      Int
  provider_request_id    String?
  flow_type              DataPullFlowType?
  status                 DataPullJobStatus  @default(PENDING)
  next_run_at            DateTime?
  attempt_count          Int                @default(0)
  maximum_attempts       Int?
  locked_at              DateTime?
  locked_by              String?
  lock_expires_at        DateTime?
  lock_token             String?            @db.Uuid
  processing_deadline_at DateTime?
  last_error             String?            @db.Text
  completed_at           DateTime?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  case                   Case               @relation(fields: [case_id], references: [id])
  applicant              Applicant?         @relation(fields: [applicant_id], references: [id])
  tenant                 Tenant             @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, case_id, pull_type, module_request_id])
  @@index([status, next_run_at])
  @@index([status, lock_expires_at])
  @@index([tenant_id, case_id])
  @@index([pull_type, status])
  @@index([provider_request_id])
}

model SystemNotification {
  id                   Int                    @id @default(autoincrement())
  tenant_id            Int
  case_id              Int
  applicant_id         Int?
  pull_type            DataPullType
  status               PullNotificationStatus
  message              String                 @db.Text
  audience_type        NotificationAudienceType
  recipient_user_id    Int?
  deduplication_key    String                 @unique
  read_at              DateTime?
  dismissed_at         DateTime?
  action_url           String?
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt

  case                 Case                   @relation(fields: [case_id], references: [id])
  tenant               Tenant                 @relation(fields: [tenant_id], references: [id])
  recipient            User?                  @relation(fields: [recipient_user_id], references: [id])
}

model VendorApiAuditLog {
  id                     Int       @id @default(autoincrement())
  job_id                 Int?
  tenant_id              Int
  case_id                Int?
  applicant_id           Int?
  pull_type              String?
  provider               String?
  provider_request_id    String?
  attempt_number         Int
  provider_operation     String
  trigger_source         String    // 'INITIAL_REQUEST', 'BACKGROUND_RECONCILIATION', etc.
  chargeable             Boolean
  tenant_wallet_deducted Boolean   @default(false)
  started_at             DateTime
  finished_at            DateTime?
  result_status          String?   // 'SUCCESS', 'ERROR'
  http_status            Int?
  error_category         String?
  created_at             DateTime  @default(now())
}
