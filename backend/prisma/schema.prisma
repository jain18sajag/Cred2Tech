  tenant_lender_id      Int?
  scheme_id             Int?
  case_esr_financial_id Int?
  proposal_source_id    Int?
  child_case_id         Int?

  proposal_number          String  @unique
  proposal_status          String  @default("draft")
  lender_submission_status String? @default("draft")

  requested_amount Float?
  eligible_amount  Float?
  roi_min          Float?
  roi_max          Float?
  tenure_months    Int?
  processing_fee   Float?

  loan_purpose              String?
  remarks                   String?
  additional_notes          String?
