  application_data   Json?
  msme_notes         String?
  agent_notes        String?
  admin_notes        String?
  last_contact_at    DateTime? @db.Timestamp(6)
  contact_count      Int?      @default(0)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
