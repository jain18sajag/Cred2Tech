  case          Case               @relation(fields: [case_id], references: [id])
  lender        Lender?            @relation(fields: [lender_id], references: [id])
  tenant_lender TenantLender?      @relation(fields: [tenant_lender_id], references: [id])
  documents     ProposalDocument[]

  @@index([tenant_lender_id])
  @@map("proposals")
}

model ProposalDocument {
  id            Int     @id @default(autoincrement())
  proposal_id   Int
  document_id   Int
  document_type String?

  proposal Proposal @relation(fields: [proposal_id], references: [id], onDelete: Cascade)
  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@unique([proposal_id, document_id])
  @@map("proposal_documents")
}

// ─── Sanction & Disbursement Flow ──────────────────────────────────────────

model CaseSanction {
  id        Int @id @default(autoincrement())
  tenant_id Int
  case_id   Int @unique

  // Snapshotted from selection/ESR
  tenant_lender_id Int?
  lender_name      String
  product_type     String

  loan_account_number String
  sanction_date       DateTime
  sanctioned_amount   Decimal  @db.Decimal(18, 2)
  confirmed_roi       Decimal  @db.Decimal(18, 4)
  processing_fee      Decimal  @db.Decimal(18, 2)

  remarks            String?
  created_by_user_id Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenant_id], references: [id])
  case_entity   Case           @relation(fields: [case_id], references: [id])
  disbursements Disbursement[]

  @@map("case_sanctions")
}

enum DisbursementStatus {
  RECORDED
  CANCELLED
}

model Disbursement {
  id               Int @id @default(autoincrement())
  tenant_id        Int
  case_id          Int
  case_sanction_id Int

  // Snapshotted from sanction at time of entry
  tenant_lender_id Int?
  lender_name      String
  product_type     String

  tranche_number             Int
  amount                     Decimal   @db.Decimal(18, 2)
  disbursement_date          DateTime
  next_disbursement_due_date DateTime?

  status          DisbursementStatus @default(RECORDED)
  remarks         String?
  idempotency_key String?

  created_by_user_id Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant               Tenant                 @relation(fields: [tenant_id], references: [id])
  case_entity          Case                   @relation(fields: [case_id], references: [id])
  sanction             CaseSanction           @relation(fields: [case_sanction_id], references: [id])
  pdd_tasks            PDDTask[]
  commission_ledgers   CommissionLedger[]
  SalesIncentiveLedger SalesIncentiveLedger[]

  @@unique([tenant_id, case_id, idempotency_key])
  @@map("disbursements")
}

enum PDDTaskStatus {
  PENDING
  RECEIVED
  WAIVED
}

enum PDDTaskSource {
  DISBURSEMENT
  MANUAL
}

model PDDTask {
  id              Int  @id @default(autoincrement())
  tenant_id       Int
  case_id         Int
  disbursement_id Int?

  document_name String
  due_date      DateTime?
  status        PDDTaskStatus @default(PENDING)
  source_type   PDDTaskSource @default(MANUAL)

  collection_date DateTime?
  collected_by    String?
  waiver_reason   String?

  remarks            String?
  created_by_user_id Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenant_id], references: [id])
  case_entity  Case          @relation(fields: [case_id], references: [id])
  disbursement Disbursement? @relation(fields: [disbursement_id], references: [id])

  @@map("pdd_tasks")
}

// ─── Salary Slip OCR System ───────────────────────────────────────────────────

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model SalarySlipOcrResult {
  id           Int  @id @default(autoincrement())
  tenant_id    Int
  customer_id  Int
  case_id      Int
  applicant_id Int
  document_id  Int? @unique

  month      String // e.g. "February" or "02"
  year       String // e.g. "2026"
  ocr_status OcrStatus @default(PENDING)
  source     String    @default("OCR") // OCR | MANUAL

  gross_salary  Float?
  net_salary    Float?
  deductions    Float?
  employer_name String?
  employee_name String?

  vendor_name      String?
  vendor_job_id    String?
  raw_ocr_response Json?
  extracted_json   Json?
  error_message    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant      Tenant    @relation(fields: [tenant_id], references: [id])
  customer    Customer  @relation(fields: [customer_id], references: [id])
  case_entity Case      @relation(fields: [case_id], references: [id])
  applicant   Applicant @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
  document    Document? @relation(fields: [document_id], references: [id])

  @@unique([case_id, applicant_id, month, year])
  @@map("salary_slip_ocr_results")
}

// ─── Commission Ledger Models ────────────────────────────────────────────────

enum CommissionLedgerStatus {
  PENDING
  INVOICED
  PAID
  CANCELLED
}

enum CommissionEntryType {
  BASE_COMMISSION
  REVERSAL
  MANUAL_ADJUSTMENT
  VOLUME_ADJUSTMENT
}

model CommissionLedger {
  id              Int  @id @default(autoincrement())
  tenant_id       Int
  case_id         Int
  disbursement_id Int? // Nullable for manual adjustments

  entry_type     CommissionEntryType @default(BASE_COMMISSION)
  reversal_of_id Int? // Links to original entry if this is a reversal
  is_reversed    Boolean             @default(false)
  reversed_at    DateTime?
  reversed_by    Int?

  tenant_lender_id Int?

  lender_name  String
  product_type String

  payout_basis    String
  commission_type String

  disbursed_amount      Decimal @db.Decimal(18, 2)
  calculated_commission Decimal @db.Decimal(18, 2)

  // Immutable Snapshots
  slab_snapshot        Json
  calculation_snapshot Json

  status  CommissionLedgerStatus @default(PENDING)
  remarks String?

  created_by_user_id Int
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenant_id], references: [id])
  case_entity    Case               @relation(fields: [case_id], references: [id])
  disbursement   Disbursement?      @relation(fields: [disbursement_id], references: [id])
  original_entry CommissionLedger?  @relation("LedgerReversals", fields: [reversal_of_id], references: [id])
  reversals      CommissionLedger[] @relation("LedgerReversals")

  @@index([tenant_id, status])
  @@index([case_id])
  @@map("commission_ledgers")
}

// ----------------------------------------------------------------------
// SubDSA Payout Module
// ----------------------------------------------------------------------

model SubDsaPayoutRule {
  id                  Int     @id @default(autoincrement())
  tenant_id           Int
  sub_dsa_user_id     Int     @unique
  default_payout_rate Float
  payout_trigger      String
  tds_applicable      Boolean @default(true)

  overrides        SubDsaLenderOverride[]
  case_count_slabs SubDsaCaseCountSlab[]
  special_schemes  SubDsaSpecialScheme[]

  user   User   @relation(fields: [sub_dsa_user_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("sub_dsa_payout_rules")
}

model SubDsaLenderOverride {
  id               Int       @id @default(autoincrement())
  rule_id          Int
  tenant_lender_id Int
  products         String
  override_rate    Float
  effective_from   DateTime?

  rule SubDsaPayoutRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@map("sub_dsa_lender_overrides")
}

model SubDsaCaseCountSlab {
  id              Int   @id @default(autoincrement())
  rule_id         Int
  from_cases      Int
  to_cases        Int?
  payout_per_case Float

  rule SubDsaPayoutRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@map("sub_dsa_case_count_slabs")
}

model SubDsaSpecialScheme {
  id               Int      @id @default(autoincrement())
  rule_id          Int
  scheme_name      String
  basis            String
  tenant_lender_id Int?
  products         String?
  valid_from       DateTime
  valid_to         DateTime
  bonus_per_case   Float?
  bonus_percent    Float?
  min_case_count   Int?
  is_active        Boolean  @default(true)

  rule SubDsaPayoutRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@map("sub_dsa_special_schemes")
}

enum SubDsaPayoutStatus {
  DRAFT
  INVOICE_RAISED
  UNDER_REVIEW
  RECONCILED
  PDD_PENDING
  PAID
  REJECTED
}

model SubDsaPayoutLedger {
  id                   Int @id @default(autoincrement())
  tenant_id            Int
  sub_dsa_user_id      Int
  case_id              Int
  commission_ledger_id Int @unique

  dsa_earned_amount Decimal @db.Decimal(18, 2)
  sub_dsa_payout    Decimal @db.Decimal(18, 2)
  subvention_amount Decimal @default(0) @db.Decimal(18, 2)
  adjustment_amount Decimal @default(0) @db.Decimal(18, 2)
  adjustment_reason String?
  tds_amount        Decimal @default(0) @db.Decimal(18, 2)
  net_payable       Decimal @db.Decimal(18, 2)

  status     SubDsaPayoutStatus @default(DRAFT)
  invoice_id Int?
  remarks    String?

  // Immutable Snapshots
  applied_scheme_snapshot Json?
  calculation_metadata    Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant      Tenant                @relation(fields: [tenant_id], references: [id])
  user        User                  @relation(fields: [sub_dsa_user_id], references: [id])
  case_entity Case                  @relation(fields: [case_id], references: [id])
  invoice     SubDsaInvoice?        @relation(fields: [invoice_id], references: [id])
  history     SubDsaPayoutHistory[]

  @@index([tenant_id, sub_dsa_user_id, status])
  @@index([invoice_id])
  @@map("sub_dsa_payout_ledgers")
}

model SubDsaInvoice {
  id              Int                @id @default(autoincrement())
  tenant_id       Int
  sub_dsa_user_id Int
  invoice_number  String             @unique
  month_year      String
  total_payout    Decimal            @db.Decimal(18, 2)
  status          SubDsaPayoutStatus @default(INVOICE_RAISED)
  pdf_url         String?
  created_at      DateTime           @default(now())

  items SubDsaPayoutLedger[]

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [sub_dsa_user_id], references: [id])

  @@map("sub_dsa_invoices")
}

model SubDsaPayoutHistory {
  id            Int                 @id @default(autoincrement())
  ledger_id     Int
  old_status    SubDsaPayoutStatus?
  new_status    SubDsaPayoutStatus
  remarks       String?
  updated_by_id Int
  updated_at    DateTime            @default(now())

  ledger     SubDsaPayoutLedger @relation(fields: [ledger_id], references: [id], onDelete: Cascade)
  updated_by User               @relation(fields: [updated_by_id], references: [id])

  @@map("sub_dsa_payout_history")
}

model EmployeeWallet {
  id                Int      @id @default(autoincrement())
  tenant_id         Int
  user_id           Int
  allocated_balance Int      @default(0)
  consumed_credits  Int      @default(0)
  status            String   @default("ACTIVE")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@unique([tenant_id, user_id])
  @@index([tenant_id])
  @@map("employee_wallets")
}

model EmployeeWalletTransaction {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  user_id            Int
  type               String // ALLOCATE, REVOKE, DEBIT_USAGE, REFUND_USAGE
  credits            Int
  opening_balance    Int
  closing_balance    Int
  reference_type     String?
  reference_id       String?
  idempotency_key    String?  @unique
  created_by_user_id Int?
  metadata           Json?
  created_at         DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@index([tenant_id, user_id])
  @@map("employee_wallet_transactions")
}

// --- Sales Incentive Models ---

enum IncentiveCommissionType {
  PERCENTAGE
  FIXED
}

enum IncentiveCalculationBase {
  DISBURSED_AMOUNT
  LENDER_COMMISSION
  DSA_NET_COMMISSION
  PROCESSING_FEE
  FIXED_PER_CASE
}

enum SalesIncentiveStatus {
  CALCULATED
  APPROVED
  PAID
  REJECTED
  ON_HOLD
  RULE_NOT_CONFIGURED
  OWNER_NOT_CONFIGURED
}

model SalesIncentiveRule {
  id               Int                      @id @default(autoincrement())
  tenant_id        Int
  hierarchy_level  String
  product_type     String?
  tenant_lender_id Int?
  commission_type  IncentiveCommissionType
  commission_value Decimal                  @db.Decimal(10, 2)
  calculation_base IncentiveCalculationBase
  min_amount       Decimal?                 @db.Decimal(18, 2)
  max_cap_amount   Decimal?                 @db.Decimal(18, 2)
  effective_from   DateTime?
  effective_to     DateTime?
  status           String                   @default("ACTIVE") // ACTIVE | INACTIVE

  created_by Int?
  updated_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant                 @relation(fields: [tenant_id], references: [id])
  lender  TenantLender?          @relation(fields: [tenant_lender_id], references: [id])
  ledgers SalesIncentiveLedger[]

  @@map("sales_incentive_rules")
}

model SalesIncentiveLedger {
  id                   Int  @id @default(autoincrement())
  tenant_id            Int
  user_id              Int? // Optional because if OWNER_NOT_CONFIGURED, we might track the gap
  case_id              Int
  disbursement_id      Int?
  commission_ledger_id Int?

  idempotency_key String @unique // INCENTIVE:<tenant_id>:<case_id>:<user_id>:<disb_id_or_CASE>:<rule_id>

  hierarchy_level String?
  rule_id         Int?

  base_amount          Decimal? @db.Decimal(18, 2)
  calculated_incentive Decimal? @db.Decimal(18, 2)

  status  SalesIncentiveStatus @default(CALCULATED)
  remarks String?

  calculation_metadata Json?

  approved_by   Int?
  approved_at   DateTime?
  paid_by       Int?
  paid_at       DateTime?
  rejected_by   Int?
  rejected_at   DateTime?
  payout_period String? // e.g. "2026-06"

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenant_id], references: [id])
  user         User?               @relation(fields: [user_id], references: [id])
  case_entity  Case                @relation(fields: [case_id], references: [id])
  rule         SalesIncentiveRule? @relation(fields: [rule_id], references: [id])
  disbursement Disbursement?       @relation(fields: [disbursement_id], references: [id])

  @@map("sales_incentive_ledgers")
}
