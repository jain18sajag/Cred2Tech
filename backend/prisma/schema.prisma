  turnover_latest_year    Decimal? @db.Decimal(18, 2)
  turnover_previous_year  Decimal? @db.Decimal(18, 2)
  financial_year_latest   String? // e.g. "FY 2024-25"
  financial_year_previous String? // e.g. "FY 2023-24"
