generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  CRED2TECH
  DSA
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model Tenant {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  mobile       String?
  type         TenantType
  status       TenantStatus @default(ACTIVE)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  
  // Audit tracking fields
  created_by   Int?
  updated_by   Int?

  // Compliance metadata fields
  pan_number   String?
  gst_number   String?
  company_type String?
  state        String?
  city         String?
  pincode      String?

  users        User[]
  customers    Customer[]
  cases        Case[]
  otps         OtpVerification[]
  wallet                TenantWallet?
  transactions          WalletTransaction[]
  api_logs              ApiUsageLog[]
  api_pricing_overrides TenantApiPricingOverride[]
  gst_requests          GstrAnalyticsRequest[]
  bank_statements       BankStatementAnalysisRequest[]
  itr_analytics         ItrAnalyticsRequest[]
  documents             Document[]

  @@map("tenants")
}

model User {
  id              Int        @id @default(autoincrement())
  name            String
  email           String     @unique
  mobile          String?
  password_hash   String
  role_id         Int
  tenant_id       Int
  hierarchy_level String?
  manager_id      Int?
  hierarchy_path  String?
  status          UserStatus @default(ACTIVE)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  created_by      Int?
  updated_by      Int?
  last_login_at   DateTime?

  role            Role       @relation(fields: [role_id], references: [id])
  tenant          Tenant     @relation(fields: [tenant_id], references: [id])
  manager         User?      @relation("UserToManager", fields: [manager_id], references: [id])
  subordinates    User[]     @relation("UserToManager")

  @@index([tenant_id])
  @@index([manager_id])

  created_customers Customer[] @relation("CustomerCreator")
  created_cases     Case[]            @relation("CaseCreator")
  created_otps      OtpVerification[] @relation("OtpCreator")
  api_logs          ApiUsageLog[]
  activity_logs     ActivityLog[]

  @@map("users")
}

// --- Onboarding Flow Models ---

model Customer {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  business_pan       String
  business_name      String?
  business_mobile    String?
  business_email     String?
  entity_type        String?
  industry           String?
  business_vintage   String?
  mobile_verified    Boolean   @default(false)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  created_by_user_id Int

  tenant         Tenant        @relation(fields: [tenant_id], references: [id])
  created_by     User          @relation("CustomerCreator", fields: [created_by_user_id], references: [id])
  cases          Case[]
  api_logs       ApiUsageLog[]
  activity_logs  ActivityLog[]
  consents       CustomerConsent[]
  gst_profiles    CustomerGSTProfile[]
  pan_profiles    CustomerPanProfile[]
  gst_requests    GstrAnalyticsRequest[]
  bank_statements BankStatementAnalysisRequest[]
  itr_analytics   ItrAnalyticsRequest[]
  documents       Document[]

  @@unique([tenant_id, business_pan])
  @@map("customers")
}

model CustomerPanProfile {
  id                        Int       @id @default(autoincrement())
  customer_id               Int
  pan                       String    @unique
  gstin                     String?
  constitution_of_business  String?
  legal_name                String?
  trade_name                String?
  principal_state           String?
  principal_city            String?
  principal_pincode         String?
  principal_address         String?
  director_names            Json?
  annual_turnover_range     String?
  turnover_min              Float?
  turnover_max              Float?
  gross_total_income        String?
  income_financial_year     String?
  raw_response              Json
  created_at                DateTime  @default(now())

  customer                  Customer  @relation(fields: [customer_id], references: [id])
  gstin_records             CustomerPanGstinRecord[]

  @@map("customer_pan_profiles")
}

model CustomerPanGstinRecord {
  id                Int       @id @default(autoincrement())
  pan_profile_id    Int
  gstin             String
  registration_name String?
  status            String?
  created_at        DateTime  @default(now())

  pan_profile       CustomerPanProfile @relation(fields: [pan_profile_id], references: [id])

  @@map("customer_pan_gstin_records")
}

enum CaseStage {
  DRAFT
  LEAD_CREATED
  DATA_COLLECTION
  INCOME_REVIEWED
  ESR_GENERATED
  IN_REVIEW
  APPROVED
  REJECTED
}

model Case {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  customer_id        Int
  product_type       String?   // LAP, HL, WC, TL, ML, BL, Other
  loan_amount        Float?
  lender_name        String?   // DEPRECATED: use case_lender_selections (Phase 2)
  property_type      String?   // DEPRECATED: use case_property_details
  occupancy          String?   // DEPRECATED: use case_property_details
  property_value     Float?    // DEPRECATED: use case_property_details
  location           String?   // DEPRECATED: use case_property_details
  ltv_ratio          Float?    // DEPRECATED: computed during ESR
  dsa_notes          String?
  esr_generated      Boolean   @default(false)  // NEW Phase 1
  stage              CaseStage @default(DRAFT)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  created_by_user_id Int

  tenant           Tenant                        @relation(fields: [tenant_id], references: [id])
  customer         Customer                      @relation(fields: [customer_id], references: [id])
  created_by       User                          @relation("CaseCreator", fields: [created_by_user_id], references: [id])
  applicants       Applicant[]
  api_logs         ApiUsageLog[]
  activity_logs    ActivityLog[]
  data_pull_status CaseDataPullStatus?
  consents         CustomerConsent[]
  gst_requests     GstrAnalyticsRequest[]
  bank_statements  BankStatementAnalysisRequest[]
  itr_analytics    ItrAnalyticsRequest[]
  bureau_checks    BureauVerification[]
  documents        Document[]
  // Phase 1 relations
  property         CasePropertyDetails?
  income_entries   CaseIncomeEntry[]
  obligations      CaseCreditObligation[]
  esr              EligibilityReport?
  esr_financials   CaseEsrFinancials?

  @@map("cases")
}

enum ApplicantType {
  PRIMARY
  CO_APPLICANT
}

model Applicant {
  id             Int           @id @default(autoincrement())
  case_id        Int
  type           ApplicantType
  name           String?       // Phase 1: display name for bureau/income pages
  pan_number     String?
  mobile         String?
  email          String?
  cibil_score    Int?
  emi            Float?        // DEPRECATED: use sum of CaseCreditObligation.emi_per_month
  otp_verified   Boolean       @default(false)
  bureau_fetched Boolean       @default(false)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  case            Case                         @relation(fields: [case_id], references: [id], onDelete: Cascade)
  bank_statements BankStatementAnalysisRequest[]
  itr_analytics   ItrAnalyticsRequest[]
  bureau_checks   BureauVerification[]
  documents       Document[]
  // Phase 1 relations
  income_entries  CaseIncomeEntry[]
  obligations     CaseCreditObligation[]

  @@map("applicants")
}

model ActivityLog {
  id                   Int      @id @default(autoincrement())
  case_id              Int?
  customer_id          Int?
  activity_type        String
  description          String?
  performed_by_user_id Int?
  created_at           DateTime @default(now())

  case_entity Case?     @relation(fields: [case_id], references: [id])
  customer    Customer? @relation(fields: [customer_id], references: [id])
  user        User?     @relation(fields: [performed_by_user_id], references: [id])

  @@index([case_id])
  @@index([customer_id])
  @@map("activity_logs")
}

enum OtpPurpose {
  PRIMARY_APPLICANT
  CO_APPLICANT
}

enum OtpTargetType {
  CUSTOMER
  APPLICANT
}

model OtpVerification {
  id                 Int           @id @default(autoincrement())
  tenant_id          Int
  created_by_user_id Int
  mobile             String
  otp_hash           String
  purpose            OtpPurpose
  target_type        OtpTargetType
  target_id          Int
  is_verified        Boolean       @default(false)
  expires_at         DateTime
  attempt_count      Int           @default(0)
  created_at         DateTime      @default(now())
  verified_at        DateTime?
  
  tenant             Tenant        @relation(fields: [tenant_id], references: [id])
  created_by         User          @relation("OtpCreator", fields: [created_by_user_id], references: [id])

  @@index([tenant_id, target_type, target_id])
  @@index([mobile])
  @@map("otp_verifications")
}

// --- Wallet & Credit Billing Models ---

model ApiPricing {
  id                  Int      @id @default(autoincrement())
  api_code            String   @unique
  api_name            String?
  default_credit_cost Int      @default(0)
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  updated_by          Int?

  @@map("api_pricing")
}

model TenantApiPricingOverride {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  api_code           String
  custom_credit_cost Int
  created_at         DateTime @default(now())
  
  tenant             Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, api_code])
  @@map("tenant_api_pricing_overrides")
}

enum WalletStatus {
  ACTIVE
  BLOCKED
}

model TenantWallet {
  id         Int          @id @default(autoincrement())
  tenant_id  Int          @unique
  balance    Int          @default(0)
  status     WalletStatus @default(ACTIVE)
  updated_at DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("tenant_wallets")
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionReferenceType {
  API_CALL
  ADMIN_TOPUP
  REFUND
  MANUAL_ADJUSTMENT
}

model WalletTransaction {
  id               Int                      @id @default(autoincrement())
  tenant_id        Int
  amount           Int
  transaction_type TransactionType
  reference_type   TransactionReferenceType
  reference_id     Int?
  api_code         String?
  remarks          String?
  balance_after    Int
  created_by       Int?
  created_at       DateTime                 @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("wallet_transactions")
}

enum ApiUsageStatus {
  SUCCESS
  FAILED
  REFUNDED
  BLOCKED_INSUFFICIENT_CREDITS
  BLOCKED_INACTIVE_API
}

model ApiUsageLog {
  id                   Int            @id @default(autoincrement())
  tenant_id            Int
  triggered_by_user_id Int
  customer_id          Int
  case_id              Int?
  api_code             String
  credits_used         Int            @default(0)
  status               ApiUsageStatus
  request_payload      Json?
  response_status      String?
  error_message        String?
  reference_id         Int?
  idempotency_key      String?
  created_at           DateTime       @default(now())

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  user        User     @relation(fields: [triggered_by_user_id], references: [id])
  customer    Customer @relation(fields: [customer_id], references: [id])
  case_entity Case?    @relation(fields: [case_id], references: [id])

  @@index([tenant_id, api_code])
  @@index([customer_id])
  @@unique([tenant_id, api_code, idempotency_key])
  @@map("api_usage_logs")
}

// --- API Integrations & Financial Pulls ---

enum ConsentType {
  GST
  ITR
  PAN
}

enum ConsentSource {
  DIRECT_LOGIN
  LINK_SENT
}

enum ConsentStatus {
  GRANTED
  PENDING
  REVOKED
}

model CustomerConsent {
  id             Int           @id @default(autoincrement())
  customer_id    Int
  case_id        Int?
  consent_type   ConsentType
  consent_source ConsentSource
  status         ConsentStatus
  granted_at     DateTime?
  created_at     DateTime      @default(now())

  customer    Customer @relation(fields: [customer_id], references: [id])
  case_entity Case?    @relation(fields: [case_id], references: [id])

  @@map("customer_consents")
}

model CustomerGSTProfile {
  id                 Int      @id @default(autoincrement())
  customer_id        Int
  gstin              String
  filing_status      String
  last_filed_period  String
  annual_turnover    Float
  raw_response       Json
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])

  @@map("customer_gst_profiles")
}

enum GstrRequestMode {
  AUTH_LINK
  IN_SYSTEM
}

enum GstrAuthType {
  OTP
  PASSWORD
}

enum GstrAnalyticsStatus {
  INITIATED
  AUTH_LINK_CREATED
  OTP_PENDING
  OTP_VERIFIED
  PROCESSING
  DATA_READY
  REPORT_READY
  CALLBACK_RECEIVED
  COMPLETED
  FAILED
  EXPIRED
}

model GstrAnalyticsRequest {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  customer_id        Int
  case_id            Int?
  mode               GstrRequestMode
  auth_type          GstrAuthType?
  gstin              String
  username           String?
  from_date          String
  to_date            String
  entity_details     Boolean  @default(false)
  pdf_url_requested  Boolean  @default(false)
  emails             Json?    
  mobile_numbers     Json?    
  callback_url       String?
  provider_request_id String? @unique
  auth_link          String?
  status             GstrAnalyticsStatus @default(INITIATED)
  provider_message   String?
  raw_gst_data       Json?
  report_json_url    String?   // Source audit URL — NOT used for serving
  report_excel_url   String?   // Source audit URL — NOT used for serving
  report_pdf_url     String?   // Source audit URL — NOT used for serving
  callback_payload   Json?
  wallet_transaction_id Int?
  otp_attempts       Int      @default(0)
  // Document storage references (populated after vendor URL ingestion)
  gst_pdf_document_id   Int?
  gst_excel_document_id Int?
  gst_json_document_id  Int?

  // Income snapshot — populated at callback ingestion time
  turnover_latest_year    Decimal?  @db.Decimal(18, 2)
  turnover_previous_year  Decimal?  @db.Decimal(18, 2)
  financial_year_latest   String?   // e.g. "FY 2024-25"
  financial_year_previous String?   // e.g. "FY 2023-24"

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id Int

  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  customer       Customer @relation(fields: [customer_id], references: [id])
  case_entity    Case?    @relation(fields: [case_id], references: [id])

  @@index([tenant_id])
  @@index([provider_request_id])
  @@map("gstr_analytics_requests")
}

// CustomerITRProfile table kept in DB for historical data; model removed in favour of ItrAnalyticsRequest

enum ItrAnalyticsStatus {
  INITIATED
  PROCESSING
  COMPLETED
  FAILED
}

model ItrAnalyticsRequest {
  id                 Int                @id @default(autoincrement())
  tenant_id          Int
  customer_id        Int
  case_id            Int?
  applicant_id       Int?
  pan                String
  reference_id       String?            @unique
  status             ItrAnalyticsStatus @default(INITIATED)
  excel_url          String?            // Source audit URL — NOT used for serving
  analytics_payload  Json?
  provider_message   String?
  // Document storage reference (populated after vendor URL ingestion)
  itr_document_id    Int?

  // Income snapshot — populated at sync completion time
  net_profit_latest_year       Decimal?  @db.Decimal(18, 2)
  net_profit_previous_year     Decimal?  @db.Decimal(18, 2)
  gross_receipts_latest_year   Decimal?  @db.Decimal(18, 2)
  gross_receipts_previous_year Decimal?  @db.Decimal(18, 2)
  financial_year_latest        String?
  financial_year_previous      String?

  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  created_by_user_id Int

  tenant      Tenant     @relation(fields: [tenant_id], references: [id])
  customer    Customer   @relation(fields: [customer_id], references: [id])
  case_entity Case?      @relation(fields: [case_id], references: [id])
  applicant   Applicant? @relation(fields: [applicant_id], references: [id])

  @@index([tenant_id])
  @@index([reference_id])
  @@map("itr_analytics_requests")
}

enum BankStatementStatus {
  INITIATED
  PRE_ANALYZING
  ANALYZING
  COMPLETED
  FAILED
}

model BankStatementAnalysisRequest {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  customer_id        Int
  case_id            Int?
  applicant_id       Int?      
  auth_token         String?   
  report_id          String?   @unique
  status             BankStatementStatus @default(INITIATED)
  provider_message   String?
  report_json_url    String?
  report_excel_url   String?
  files_payload      Json?
  
  raw_analyze_response   Json?
  raw_retrieve_response  Json?
  raw_download_response  Json?

  wallet_transaction_id Int?

  // Document storage references (populated after vendor URL ingestion)
  bank_excel_document_id Int?
  bank_json_document_id  Int?

  // Income snapshot — populated when bank analysis completes
  avg_bank_balance_latest_year   Decimal?  @db.Decimal(18, 2)
  avg_bank_balance_previous_year Decimal?  @db.Decimal(18, 2)
  financial_year_latest          String?
  financial_year_previous        String?

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id Int

  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  customer       Customer @relation(fields: [customer_id], references: [id])
  case_entity    Case?    @relation(fields: [case_id], references: [id])
  applicant      Applicant? @relation(fields: [applicant_id], references: [id])

  @@index([tenant_id])
  @@index([report_id])
  @@map("bank_statement_analysis_requests")
}

enum DataPullStatus {
  PENDING
  COMPLETE
  FAILED
}

model CaseDataPullStatus {
  id            Int            @id @default(autoincrement())
  case_id       Int            @unique
  pan_status    DataPullStatus @default(PENDING)
  bureau_status DataPullStatus @default(PENDING)
  gst_status    DataPullStatus @default(PENDING)
  itr_status    DataPullStatus @default(PENDING)
  bank_status   DataPullStatus @default(PENDING)
  updated_at    DateTime       @updatedAt

  case_entity Case @relation(fields: [case_id], references: [id])

  @@map("case_data_pull_statuses")
}

// --- Bureau Verification Models ---

model BureauVerification {
  id                String   @id @default(uuid())
  case_id           Int
  applicant_id      Int
  applicant_type    String   // PRIMARY or CO_APPLICANT
  request_id        String   @unique
  stan              String
  mobile_number     String
  score             String?
  raw_response      Json?
  status            String
  emi_obligations_total Decimal? @db.Decimal(18, 2)  // Total EMI from bureau for ESR FOIR
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  case_entity       Case      @relation(fields: [case_id], references: [id])
  applicant         Applicant @relation(fields: [applicant_id], references: [id])

  @@map("bureau_verifications")
}

model BureauVerificationLog {
  id                String   @id @default(uuid())
  case_id           Int
  applicant_id      Int
  request_payload   Json
  response_payload  Json
  status            String
  created_at        DateTime @default(now())

  @@map("bureau_verification_logs")
}

// --- Lender Configuration Matrix Models ---

enum LenderStatus {
  ACTIVE
  INACTIVE
}

model Lender {
  id         String       @id @default(uuid())
  name       String
  code       String       @unique
  status     LenderStatus @default(ACTIVE)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  created_by Int?
  updated_by Int?

  products   LenderProduct[]

  @@map("lenders")
}

enum LenderProductType {
  HL
  LAP
  WC   // Working Capital / CC / OD
  TL   // Term Loan
  ML   // Machinery / Equipment Finance
  BL   // Business Loan (Unsecured)
}

model LenderProduct {
  id           Int                @id @default(autoincrement())
  lender_id    String
  product_type LenderProductType
  status       LenderStatus       @default(ACTIVE)
  
  lender       Lender             @relation(fields: [lender_id], references: [id])
  schemes      Scheme[]

  @@unique([lender_id, product_type])
  @@map("lender_products")
}

model Scheme {
  id          Int            @id @default(autoincrement())
  product_id  Int
  scheme_name String
  status      LenderStatus   @default(ACTIVE)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  created_by  Int?
  updated_by  Int?

  product          LenderProduct          @relation(fields: [product_id], references: [id])
  parameter_values SchemeParameterValue[]

  @@map("schemes")
}

model ParameterMaster {
  id                Int                    @id @default(autoincrement())
  parameter_key     String                 @unique
  parameter_label   String
  category          String
  data_type         String
  display_order     Int
  is_editable_label Boolean                @default(false)

  values            SchemeParameterValue[]

  @@map("parameter_master")
}

model SchemeParameterValue {
  id           Int      @id @default(autoincrement())
  scheme_id    Int
  parameter_id Int
  value        Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  
  created_by   Int?
  updated_by   Int?

  scheme       Scheme          @relation(fields: [scheme_id], references: [id])
  parameter    ParameterMaster @relation(fields: [parameter_id], references: [id])

  @@unique([scheme_id, parameter_id])
  @@map("scheme_parameter_values")
}

// ─── Document Storage System ──────────────────────────────────────────────────

enum DocumentType {
  GST_REPORT_PDF
  GST_REPORT_EXCEL
  GST_REPORT_JSON
  ITR_EXCEL
  BANK_EXCEL
  BANK_JSON
  OTHER
}

enum DocumentSource {
  VENDOR_DOWNLOAD   // Downloaded from a vendor-provided URL (Signzy etc.)
  DIRECT_UPLOAD     // Uploaded directly by user
  SYSTEM_GENERATED  // Created internally
}

enum DocumentStatus {
  ACTIVE
  FAILED
  DELETED
}

enum StorageProvider {
  LOCAL
  CLOUDFLARE_R2
  S3
}

model Document {
  id                  Int              @id @default(autoincrement())
  tenant_id           Int
  customer_id         Int?
  case_id             Int?
  applicant_id        Int?

  document_type       DocumentType
  source_type         DocumentSource
  /// Original vendor URL kept for audit/debug — app NEVER uses this to serve
  source_url          String?

  storage_provider    StorageProvider  @default(LOCAL)
  /// Relative path/key within the storage root — never exposed to frontend
  storage_path        String

  file_name           String           // System-generated safe filename
  original_file_name  String?          // Filename as received (for display only)
  mime_type           String
  extension           String
  file_size_bytes     Int?
  checksum_md5        String?

  status              DocumentStatus   @default(ACTIVE)
  uploaded_by_user_id Int?
  metadata            Json?            // Extensible — store any extra provider data
  deleted_at          DateTime?

  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  tenant     Tenant     @relation(fields: [tenant_id], references: [id])
  customer   Customer?  @relation(fields: [customer_id], references: [id])
  case_entity Case?     @relation(fields: [case_id], references: [id])
  applicant   Applicant? @relation(fields: [applicant_id], references: [id])

  @@index([tenant_id])
  @@index([customer_id])
  @@index([case_id])
  @@index([tenant_id, document_type])
  @@map("documents")
}

// ─── Phase 1: Onboarding Extension Models ────────────────────────────────────

model CasePropertyDetails {
  id               Int      @id @default(autoincrement())
  case_id          Int      @unique
  property_type    String?  // Commercial / Residential / Industrial / Plot
  occupancy_status String?  // Self Occupied / Rented Out / Vacant
  ownership_type   String?  // Sole Owner / Joint Owner / Company Owned
  market_value     Float?   // DSA estimate in INR
  remarks          String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  case_entity      Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@map("case_property_details")
}

model CaseIncomeEntry {
  id                  Int       @id @default(autoincrement())
  case_id             Int
  applicant_id        Int?
  income_type         String    // Director Salary / Rental Income / Agriculture Income / Other...
  applicant_label     String?   // Human-readable label (e.g. "Rajesh Kumar")
  annual_amount       Float
  supporting_doc_type String?   // CA Certificate / Salary Slip / Form 16 / Bank Credit / None
  remarks             String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  case_entity         Case       @relation(fields: [case_id], references: [id], onDelete: Cascade)
  applicant           Applicant? @relation(fields: [applicant_id], references: [id], onDelete: SetNull)

  @@index([case_id])
  @@index([applicant_id])
  @@map("case_income_entries")
}

model CaseCreditObligation {
  id                  Int       @id @default(autoincrement())
  case_id             Int
  applicant_id        Int
  lender_name         String?
  loan_type           String?   // Home Loan / Car Loan / Business Loan / Personal Loan / etc.
  loan_amount         Float?
  outstanding_amount  Float?
  loan_start_date     DateTime?
  emi_per_month       Float     @default(0)
  status              String    @default("ACTIVE")  // ACTIVE | CLOSED | NPA | VERIFY
  source              String    @default("BUREAU")  // BUREAU | MANUAL
  needs_verification  Boolean   @default(false)     // true when bureau EMI = 0
  include_in_foir     Boolean   @default(true)      // NEW: For ESR FOIR calculation
  remarks             String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  case_entity         Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  applicant           Applicant @relation(fields: [applicant_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@index([applicant_id])
  @@index([case_id, applicant_id])
  @@map("case_credit_obligations")
}

model CaseEsrFinancials {
  id                    Int      @id @default(autoincrement())
  case_id               Int      @unique
  requested_loan_amount Float?
  requested_tenure_months Int?
  product_type          String?

  property_value        Float?
  property_type         String?
  occupancy_type        String?

  bureau_score          Int?
  applicant_age         Int?
  existing_obligations  Float?
  icici_exposure        Float?
  
  itr_pat               Float?
  itr_depreciation      Float?
  itr_finance_cost      Float?
  itr_gross_receipts    Float?
  
  gst_avg_monthly_sales Float?
  gst_industry_type     String?
  gst_industry_margin   Float?
  
  bank_avg_balance      Float?
  bank_monthly_income   Float?
  
  net_profit_income     Float?
  gst_income            Float?
  banking_income        Float?

  selected_income_method String?
  selected_monthly_income Float?

  constitution_type     String?
  employment_type       String?
  business_vintage_months Int?
  
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  case_entity           Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@map("case_esr_financials")
}

model EligibilityReport {
  id                    Int      @id @default(autoincrement())
  case_id               Int      @unique
  generated_at          DateTime @default(now())
  generated_by_user_id  Int?
  combined_income       Float?
  property_value        Float?
  primary_cibil_score   Int?
  lowest_cibil_score    Int?
  total_emi_per_month   Float?
  raw_payload           Json?    // Per-lender eligibility breakdown
  status                String   @default("GENERATED")
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  case_entity           Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@map("eligibility_reports")
}
